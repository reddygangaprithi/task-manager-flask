<!DOCTYPE html>
<!-- saved from url=(0030)http://127.0.0.1:5000/register -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Task Manager</title>
    <link href="./demo1-register_files/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="./demo1-register_files/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            
                <a href="http://127.0.0.1:5000/login" class="nav-link">Login</a>
                <a href="http://127.0.0.1:5000/register" class="nav-link">Register</a>
            
        </div>
    </nav>

    <div class="container">
        
            
        

        
<div class="auth-container">
    <div class="auth-card">
        <h1><i class="fas fa-user-plus"></i> Create Account</h1>
        <form method="POST" class="auth-form">
            <div class="form-group">
                <label><i class="fas fa-user"></i> Username</label>
                <input type="text" name="username" required="">
            </div>
            <div class="form-group">
                <label><i class="fas fa-envelope"></i> Email</label>
                <input type="email" name="email" required="">
            </div>
            <div class="form-group">
                <label><i class="fas fa-lock"></i> Password</label>
                <input type="password" name="password" required="" minlength="6">
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="fas fa-user-plus"></i> Register
            </button>
        </form>
        <p class="auth-link">
            Already have an account? <a href="http://127.0.0.1:5000/login">Login here</a>
        </p>
    </div>
</div>

    </div>

</body></html>