<!DOCTYPE html>
<!-- saved from url=(0031)http://127.0.0.1:5000/dashboard -->
<html lang="en"><head><meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Task Manager</title>
    <link href="./demo4-task_files/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="./demo4-task_files/style.css">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            
                <a href="http://127.0.0.1:5000/dashboard" class="nav-link">
                    <i class="fas fa-tasks"></i> Dashboard
                </a>
                <span class="user-info">Welcome, prithi!</span>
                <a href="http://127.0.0.1:5000/logout" class="nav-link logout">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            
        </div>
    </nav>

    <div class="container">
        
            
        

        
<div class="dashboard-header">
    <h1><i class="fas fa-tasks"></i> My Tasks (1)</h1>
</div>

<!-- Add Task Form -->
<div class="task-form-card">
    <h3><i class="fas fa-plus"></i> Add New Task</h3>
    <form method="POST" action="http://127.0.0.1:5000/add_task">
        <div class="form-row">
            <div class="form-group">
                <label>Title</label>
                <input type="text" name="title" required="">
            </div>
            <div class="form-group">
                <label>Priority</label>
                <select name="priority">
                    <option value="low">Low</option>
                    <option value="medium" selected="">Medium</option>
                    <option value="high">High</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Description</label>
                <textarea name="description" rows="3"></textarea>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Due Date</label>
                <input type="date" name="due_date">
            </div>
        </div>
        <button type="submit" class="btn btn-success">
            <i class="fas fa-plus"></i> Add Task
        </button>
    </form>
</div>

<!-- Tasks Grid -->
<div class="tasks-section">
    <div class="tasks-grid">
        
        <div class="task-card priority-high status-pending">
            <div class="task-header">
                <h3>workout</h3>
                <span class="priority-badge">High</span>
            </div>
            
            
            <p class="task-description">wakeup at-5am
daily 2 hours workout
</p>
            
            
            <div class="task-meta">
                
                <span class="due-date">
                    <i class="fas fa-calendar"></i> 2026-07-16
                </span>
                
                <span class="created-date">
                    <i class="fas fa-clock"></i> 2026-03-07
                </span>
            </div>
            
            <div class="task-actions">
                <form method="POST" action="http://127.0.0.1:5000/update_task/2" class="status-form">
                    <select name="status">
                        <option value="pending" selected="">Pending</option>
                        <option value="in-progress">In Progress</option>
                        <option value="completed">Completed</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary">Update</button>
                </form>
                <a href="http://127.0.0.1:5000/delete_task/2" class="btn btn-sm btn-danger" onclick="return confirm(&#39;Are you sure you want to delete this task?&#39;)">
                    <i class="fas fa-trash"></i> Delete
                </a>
            </div>
        </div>
        
    </div>
</div>

    </div>

</body></html>